    "\n",
    "        # Save dimensions for derived calculations\n",
    "        self.gru_hidden_size = gru_hidden_size\n",
    "\n",
    "        # Embedding layer\n",
    "        self.embedding = nn.Embedding(\n",
    "            num_embeddings=vocab_size, embedding_dim=embedding_dim, padding_idx=0\n",
    "        )\n",
    "\n",
    "        # Copiamos los pesos del embedding preentrenado si se proporciona y configuramos su entrenamiento\n",
    "        if embedding_matrix is not None:\n",
    "            self.embedding.weight.data.copy_(embedding_matrix)\n",
    "            if not embedding_trainable:\n",
    "                self.embedding.weight.requires_grad = False\n",
    "\n",
    "        # Spatial Dropout de dimensiones del embedding\n",
    "        self.spatial_dropout = nn.Dropout1d(p=0.2)\n",
    "\n",
    "        # GRU layer\n",
    "        self.gru = nn.GRU(\n",
    "            input_size=embedding_dim, hidden_size=self.gru_hidden_size, batch_first=True\n",
    "        )\n",
    "\n",
    "        # Capas densas con batch normalization\n",
    "        self.dense1 = nn.Linear(self.gru_hidden_size * 2, embedding_dim)\n",
    "        self.batch_norm1 = nn.BatchNorm1d(embedding_dim)\n",
    "        self.dropout = nn.Dropout(p=0.2)\n",
    "        self.dense2 = nn.Linear(embedding_dim, num_classes)\n",
    "\n",
